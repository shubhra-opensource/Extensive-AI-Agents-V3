{
    "manifest_version": 3,
    "name": "Job Gap Coach v3",
    "version": "3.0.0",
    "description": "Compare resume skills with the current job page and show technical gaps.",
    "permissions": ["storage", "sidePanel", "tabs", "downloads"],
    "host_permissions": [
      "<all_urls>",
      "https://generativelanguage.googleapis.com/*"
    ],
    "background": {
      "service_worker": "background.js"
    },
    "action": {
      "default_title": "Open Job Gap Coach"
    },
    "side_panel": {
      "default_path": "sidepanel.html"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "run_at": "document_idle"
      }
    ]
  }